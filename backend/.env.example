# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# ─── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/hotel_management"
MONGODB_URI="mongodb://localhost:27017/hotel-management"

# ─── JWT Authentication ───────────────────────────────────
# IMPORTANT: Use strong random strings (32+ characters) in production
# Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET="change-this-to-a-random-64-char-string"
JWT_REFRESH_SECRET="change-this-to-another-random-64-char-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Cloudinary (Image Upload) ────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Stripe (Payments) ────────────────────────────────────
# In production, ensure STRIPE_WEBHOOK_SECRET is set for webhook verification
STRIPE_SECRET_KEY="your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"

# ─── Razorpay (Payments) ────────────────────────────────
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

# ─── PayPal (Payments) ──────────────────────────────────
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_ENVIRONMENT="sandbox"

# ─── Google OAuth ────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"

# ─── Email (Nodemailer / SMTP) ───────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@hotelmanagement.com"

# ─── Redis (Caching / Queue) ──────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL="debug"
LOG_FORMAT="dev"
