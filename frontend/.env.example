# ─── API Configuration ────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# ─── Site Configuration ───────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=HotelManager

# ─── Feature Flags ────────────────────────────────────────
NEXT_PUBLIC_ENABLE_MONGO_AUTH=true

# ─── Pexels API (for stock hotel/room images) ────────────
NEXT_PUBLIC_PIXEL_API_KEY="your-pexels-api-key"

# ─── Google OAuth ─────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id"
