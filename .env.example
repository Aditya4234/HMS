# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
# Local: postgresql://postgres:password@localhost:5432/hotel_management
# Neon:  postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/hotel_management

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET=change-this-to-random-64-char-string
JWT_REFRESH_SECRET=change-this-to-another-random-64-char-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:5000/api

# ─────────────────────────────────────────────
# SMTP / EMAIL (optional — for OTP, receipts)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@hotelmanagement.com

# ─────────────────────────────────────────────
# STRIPE (optional — for online payments)
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ─────────────────────────────────────────────
# RAZORPAY (optional)
# ─────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=rzp_test_xxx

# ─────────────────────────────────────────────
# PAYPAL (optional)
# ─────────────────────────────────────────────
PAYPAL_CLIENT_ID=xxx
PAYPAL_CLIENT_SECRET=xxx

# ─────────────────────────────────────────────
# CLOUDINARY (optional — for image uploads)
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─────────────────────────────────────────────
# OPENROUTER AI (optional — for AI room search)
# ─────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxx
